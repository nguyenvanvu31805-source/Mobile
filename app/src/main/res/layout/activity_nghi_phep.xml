<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f5f5f5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#2196F3" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="XIN NGHỈ PHÉP"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- Form xin nghỉ phép -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ĐĂNG KÝ NGHỈ PHÉP"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="16dp" />

        <!-- Ngày bắt đầu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày bắt đầu"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_ngay_bat_dau"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:hint="Chọn ngày bắt đầu"
            android:focusable="false"
            android:clickable="true" />

        <!-- Ngày kết thúc -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày kết thúc"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_ngay_ket_thuc"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:hint="Chọn ngày kết thúc"
            android:focusable="false"
            android:clickable="true" />

        <!-- Số ngày nghỉ -->
        <TextView
            android:id="@+id/tv_so_ngay_nghi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Số ngày nghỉ: 0 ngày"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#666"
            android:layout_marginBottom="16dp" />

        <!-- Lý do -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lý do nghỉ phép"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_ly_do"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:hint="Nhập lý do nghỉ phép"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:maxLines="3" />

        <!-- Button gửi đơn -->
        <Button
            android:id="@+id/btn_xin_nghi_phep"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="GỬI ĐƠN XIN NGHỈ PHÉP"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_primary" />

    </LinearLayout>

    <!-- Lịch sử nghỉ phép header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:padding="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LỊCH SỬ NGHỈ PHÉP"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333" />

    </LinearLayout>

    <!-- ListView có thể scroll -->
    <ListView
        android:id="@+id/lv_lich_su_nghi_phep"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@android:color/white"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"
        android:elevation="2dp" />

</LinearLayout>