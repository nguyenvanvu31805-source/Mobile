                android:textStyle="bold"
                android:textColor="#1976D2"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Smart HR là hệ thống quản lý nhân sự thông minh được phát triển với công nghệ hiện đại nhất, giúp doanh nghiệp tối ưu hóa quy trình quản lý nhân sự từ tuyển dụng đến nghỉ việc."
                android:textSize="14sp"
                android:textColor="#666"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Với giao diện thân thiện và tính năng đa dạng, Smart HR không chỉ giúp tiết kiệm thời gian mà còn nâng cao hiệu quả công việc, đảm bảo tính chính xác và minh bạch trong mọi hoạt động quản lý nhân sự."
                android:textSize="14sp"
                android:textColor="#666"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

