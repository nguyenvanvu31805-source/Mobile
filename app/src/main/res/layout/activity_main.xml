                        android:layout_height="wrap_content"
                        android:text="Hệ Thống Quản Lý Nhân Sự Thông Minh"
                        android:textSize="18sp"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:layout_marginBottom="8dp"
                        android:alpha="0.9" />

