                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Tính lương tự động theo công thức linh hoạt\n• Quản lý phụ cấp, thưởng, khấu trừ\n• Tính thuế thu nhập cá nhân tự động\n• Xuất phiếu lương điện tử\n• Báo cáo chi phí nhân sự chi tiết"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

