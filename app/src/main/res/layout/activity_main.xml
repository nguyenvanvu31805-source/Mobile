                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Đăng ký nghỉ phép online dễ dàng\n• Quy trình phê duyệt tự động theo cấp bậc\n• Theo dõi số ngày phép còn lại\n• Quản lý các loại nghỉ: phép năm, ốm, thai sản\n• Thông báo tự động cho quản lý"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

                <!-- Feature Detail 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="HỆ THỐNG TÍNH LƯƠNG CHÍNH XÁC"
                        android:textSize="16sp"
                        android:textStyle="bold"
