                        android:textColor="#333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Lưu trữ thông tin cá nhân đầy đủ và chi tiết\n• Quản lý hợp đồng lao động và phụ lục\n• Theo dõi lịch sử công tác và thăng tiến\n• Quản lý chứng chỉ và bằng cấp\n• Tạo báo cáo nhân sự theo nhiều tiêu chí"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

                <!-- Feature Detail 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="HỆ THỐNG CHẤM CÔNG THÔNG MINH"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
