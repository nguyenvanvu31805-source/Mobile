<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Thông tin nhân viên (chỉ hiện với Admin/HR) -->
    <TextView
        android:id="@+id/tv_ma_nv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã NV: NV001"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_ho_ten"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Họ tên: Nguyễn Văn A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Thông tin lương -->
    <TextView
        android:id="@+id/tv_thang_nam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tháng: 2024-01"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#f5f5f5"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_luong_co_ban"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lương cơ bản: 12.000.000 ₫"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_phu_cap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phụ cấp: 2.000.000 ₫"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_so_gio_lam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Số giờ làm: 176.0 giờ"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_so_ngay_lam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Số ngày: 22 ngày"
                android:textSize="14sp"
                android:textColor="#666" />

            <TextView
                android:id="@+id/tv_gio_tang_ca"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Giờ tăng ca: 8.0 giờ"
                android:textSize="14sp"
                android:textColor="#FF9800"
                android:gravity="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_luong_tang_ca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lương tăng ca: 865.385 ₫"
            android:textSize="14sp"
            android:textColor="#FF9800"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Tổng lương -->
    <TextView
        android:id="@+id/tv_tong_luong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tổng lương: 14.000.000 ₫"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:layout_marginBottom="8dp" />

    <!-- Trạng thái -->
    <TextView
        android:id="@+id/tv_trang_thai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trạng thái: Chưa thanh toán"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Button thanh toán -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_thanh_toan"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="THANH TOÁN"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_primary"
            android:minWidth="100dp" />

    </LinearLayout>

</LinearLayout>