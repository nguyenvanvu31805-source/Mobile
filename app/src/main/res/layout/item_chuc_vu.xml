<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Thông tin chính -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_ma_chuc_vu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã: CV001"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tv_trang_thai"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Trạng thái: Hoạt động"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <!-- Tên chức vụ -->
    <TextView
        android:id="@+id/tv_ten_chuc_vu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Giám đốc"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_marginBottom="8dp" />

    <!-- Thông tin chi tiết -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_muc_luong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mức lương cơ bản: 50.000.000 ₫"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_so_nhan_vien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Số nhân viên: 5"
            android:textSize="14sp"
            android:textColor="#666" />

    </LinearLayout>

    <!-- Buttons sửa/xóa -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_xoa"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:text="XÓA"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#F44336"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_sua"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:text="SỬA"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#2196F3" />

    </LinearLayout>

</LinearLayout>